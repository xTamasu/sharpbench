// appsettings.json
// Default configuration for the API. Values are overridden by environment variables
// in production (see docker-compose.yml). The placeholder JWT secret is *only* a
// development fallback; production deployments MUST override it.
{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=taskmanager;Username=taskmanager;Password=taskmanager_dev_pw"
  },
  "Jwt": {
    "Secret": "CHANGE_ME_super_long_dev_only_secret_key_at_least_32_chars_long_123",
    "Issuer": "TaskManager",
    "Audience": "TaskManagerClients",
    "ExpiryMinutes": 120
  }
}
